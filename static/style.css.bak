/* Styles des alertes */
.alert {
    padding: 15px;
    margin-bottom: 20px;
    border: 1px solid transparent;
    border-radius: 4px;
}

.alert-success {
    background-color: #e6f7ec;
    border-color: #c3e6cb;
    color: #2c7a58;
}

.alert-warning {
    background-color: #fffbe6;
    border-color: #ffeeba;
    color: #856404;
}

.alert-danger {
    background-color: #f8d7da;
    border-color: #f5c6cb;
    color: #a94442;
}


/* Table grande */
.table-large {
    width: 100%; /* Prend toute la largeur disponible */
    font-size: 1.2em; /* Texte plus grand */
    border-collapse: collapse;
    margin-bottom: 20px;
}

/* Table petite */
.table-small {
    width: 50%; /* Prend seulement 50% de la largeur disponible */
    font-size: 0.9em; /* Texte plus petit */
    margin: 0 auto; /* Centrée */
    border-collapse: collapse;
}

/* Styles communs */
.table-large td, .table-small td {
    padding: 10px;
    border: 1px solid #444;
    text-align: left;
}
