# =============================================================================
# ETICMONTS – Environment variables (copy to .env and fill in real values)
# =============================================================================

# Flask
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_STRING
FLASK_ENV=production

# Application timezone (used to compute order deadlines)
APP_TIMEZONE=Europe/Paris

# PostgreSQL
POSTGRES_USER=eticmont
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=eticmont
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432

# Nginx exposed port on host
NGINX_PORT=80

# PostgreSQL port exposed on host (for admin access / backups)
POSTGRES_EXTERNAL_PORT=5433

# Backup directory on host
BACKUP_DIR=/home/postgres-backups

# Registration token for new producteur accounts (sent OOB to invitees)
REGISTER_TOKEN=CHANGE_ME_TO_A_RANDOM_STRING

# Optional: bootstrap an admin account on first start if no admin exists
# (you can change the password via the UI afterwards)
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
