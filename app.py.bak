INSERT_INTO_WATER = (f'''INSERT INTO water (linked_id, year, matosirrigfr, matosirriggf, matosirrigleg, consoeau, actions) VALUES (%s, %s, %s, %s, %s, %s, %s) RETURNING id;''')
DELETE_FROM_WATER = (f'''DELETE FROM water WHERE id = (%s);''') #AND year = %s;
WATER_LIST = (f'''SELECT * FROM water''')

