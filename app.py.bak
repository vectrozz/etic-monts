DELETE_FROM_PLASTIC = (f'''DELETE FROM plastique WHERE id = (%s);''') #AND year = %s;
PLASTIC_LIST = (f'''SELECT * FROM plastique''')

INSERT_INTO_SOIL = (f'''INSERT INTO soil (linked_id, year, soilanalyse, connaissance, formation, pratique) VALUES (%s, %s, %s, %s, %s, %s) RETURNING id;''')
