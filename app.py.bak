@app.route('/addplastic', methods=['GET','POST' ])
def addplastic():
    if request.method == 'GET':
        
        if 'username' in session:
            username = session['username']
            id = session['user_id']  
            created_date = session['created_date']
            last_login_date = session['last_login_date']
            #SEARCH_CREATED_DATE = (f'''SELECT created_date FROM {TABLE_NAME} WHERE name LIKE (%s)''')
            return redirect(url_for('add', username=username, user_id=id, created_date=created_date, last_login_date=last_login_date))

    if (request.method == 'POST') & ('username' in session):
        try:
            username = session['username']
            id = session['user_id']  
            created_date = session['created_date']
            last_login_date = session['last_login_date']
        
            id = session['user_id']
            year = int(request.form['year'])
            surftotplast = float(request.form['surftotplast'])
            surftottoile = float(request.form['surftottoile'])
            paillagefr = json.dumps(request.form['paillagefr'])
            paillagegf = json.dumps(request.form['paillagegf'])
            paillageleg = json.dumps(request.form['paillageleg'])
            limitation = json.dumps(request.form['limitation'])
            embplast = json.dumps(request.form['embplast'])
            embplastpourcent = request.form['embplastpourcent']
            embfr = json.dumps(request.form['embfr'])
            embgf = json.dumps(request.form['embgf'])
            embleg = json.dumps(request.form['embleg'])

            conn = db_conn()
            curr = conn.cursor()
            curr.execute(INSERT_INTO_PLASTIC, (id, year, surftotplast, surftottoile, paillagefr, paillagegf, paillageleg, limitation, embplast, embplastpourcent, embfr, embgf, embleg))
            conn.commit()
            #curr.execute(f'''SELECT id, year, surftotplast, surftottoile, paillagefr, paillagegf, paillageleg, limitation, embplast, embplastpourcent, embfr, embgf, embleg FROM plastique WHERE linked_id = (%s)''', (id,))
            #plastique = curr.fetchall()
            curr.close()
            conn.close()

            flash(f"Plastique pour année {year} ajouté","success")

            return render_template('add.html', username=username, user_id=id, created_date=created_date, last_login_date=last_login_date)

        except errors.CheckViolation as e:
            # Handle the CheckConstraint violation
            error_message = str(e).split("\nDETAIL:")[0]  # Get the primary error message
            return f"Error: {error_message}. Mauvaise entrée.", 400

        except Exception as e:
            # Handle other exceptions
            return f"Erreur innattendue: {str(e)}", 500
        
    else:
        flash(f"Mauvaise methode ou loggez vous","error")
        #year,linked_id, year, surface_type, area, forest, hedge, bramble, pond, watercourse, wood_pile, walls, mown_area, not_worked_area, description = result
        return render_template('dashboard.html', username=username, user_id=id, created_date=created_date, last_login_date=last_login_date, year=year) 



